{
  "name": "@luma/webos",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "LUMA LG webOS TV client thin shell over @luma/tv.",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit && vite build && vite build --config vite.config.legacy.ts && bun run check:legacy",
    "check:legacy": "bun ../tv-build/check-legacy.ts",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "package": "echo 'Run: bun run build:webos, then: ares-package clients/webos/dist'"
  },
  "dependencies": {
    "@luma/core": "workspace:*",
    "@luma/tv": "workspace:*",
    "@luma/ui": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^22.10.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "lightningcss": "^1.27.0",
    "tailwindcss": "^4",
    "typescript": "^7.0.2",
    "vite": "^6.0.7"
  }
}
