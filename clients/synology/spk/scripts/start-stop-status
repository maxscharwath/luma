#!/bin/sh
# DSM 7 service control for KROMA. One process: kroma-server serves the API,
# streaming, AND the bundled web SPA on a single port. ffmpeg/ffprobe are taken
# from the bundled static copies via PATH. Config (movies/series folders, port,
# optional data folder) is written by the install wizard (postinst) to
# var/kroma.conf.

PKG="kroma"
TARGET="/var/packages/${PKG}/target"
VAR="/var/packages/${PKG}/var"
BIN="${TARGET}/bin/kroma-server"
PID="${VAR}/kroma.pid"
LOG="${VAR}/kroma.log"

# shellcheck disable=SC1090
[ -f "${VAR}/kroma.conf" ] && . "${VAR}/kroma.conf"

# Data lives in the user-chosen folder (wizard) or, by default, under the
# package's own var. If the chosen path can't be created (e.g. permissions were
# never granted), fall back to var/data so the service still starts.
DATA_DIR="${KROMA_DATA_DIR:-}"
[ -n "${DATA_DIR}" ] || DATA_DIR="${VAR}/data"

start_daemon() {
    mkdir -p "${DATA_DIR}" 2>/dev/null
    if [ ! -d "${DATA_DIR}" ]; then
        echo "$(date) data folder ${DATA_DIR} unavailable, using ${VAR}/data" >> "${LOG}"
        DATA_DIR="${VAR}/data"
    fi
    mkdir -p "${DATA_DIR}"
    PATH="${TARGET}/ffmpeg:${PATH}" \
    KROMA_PORT="${KROMA_PORT:-4040}" \
    KROMA_MOVIES_DIRS="${KROMA_MOVIES_DIRS}" \
    KROMA_SERIES_DIRS="${KROMA_SERIES_DIRS}" \
    KROMA_MEDIA_DIRS="${KROMA_MEDIA_DIRS}" \
    KROMA_DATA_DIR="${DATA_DIR}" \
    KROMA_WEB_DIR="${TARGET}/web" \
    "${BIN}" >> "${LOG}" 2>&1 &
    echo $! > "${PID}"
}

stop_daemon() {
    [ -f "${PID}" ] && kill "$(cat "${PID}")" 2>/dev/null
    rm -f "${PID}"
}

daemon_status() {
    [ -f "${PID}" ] && kill -0 "$(cat "${PID}")" 2>/dev/null
}

case "$1" in
    start)  daemon_status || start_daemon ;;
    stop)   stop_daemon ;;
    status) daemon_status && exit 0 || exit 3 ;;
    *)      exit 1 ;;
esac
exit 0
