<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    App Transport Security exceptions. KROMA connects to a self-hosted media server
    over plain HTTP on the LAN (e.g. http://192.168.x.x:4040), and the <video>
    element's media loader (AVFoundation) enforces ATS strictly - without these the
    stream request is silently blocked and playback just spins forever in the built
    .app (it works in `tauri dev` because that is served over http://localhost).
    NSAllowsLocalNetworking permits HTTP to private/LAN addresses; the arbitrary-loads
    keys cover a server reached by hostname / public IP over HTTP too.
  -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <true/>
    <key>NSAllowsArbitraryLoadsInWebContent</key>
    <true/>
    <key>NSAllowsLocalNetworking</key>
    <true/>
  </dict>
</dict>
</plist>
