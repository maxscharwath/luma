{
  "name": "@kroma/desktop",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "KROMA native desktop client: Tauri shell over @kroma/tv with native mpv playback + gamepad input. Steam Deck is the primary target.",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit && vite build",
    "build:fast": "vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles appimage",
    "tauri:build:mac": "tauri build --bundles app",
    "tauri:build:mac:dmg": "tauri build --bundles app,dmg",
    "tauri:icon": "tauri icon src-tauri/icons/icon.png"
  },
  "dependencies": {
    "@kroma/core": "workspace:*",
    "@kroma/tv": "workspace:*",
    "@kroma/ui": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.10.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
