# Config for @luma/synology-repo (the Synology package-source generator).
# `bun` auto-loads a `.env` in the working directory; CI passes these inline instead.
# Copy to `.env` and adjust. Only CATALOG_DOWNLOAD_URL + CATALOG_PAGES_URL are required.

# Public URL DSM downloads the .spk from (e.g. a GitHub Release asset). REQUIRED.
CATALOG_DOWNLOAD_URL=https://github.com/maxscharwath/luma/releases/download/v0.1.4/luma-0.1.4-x86_64.spk

# Base URL the generated repo dir is served at (used for the store icon). REQUIRED.
CATALOG_PAGES_URL=https://maxscharwath.github.io/luma

# Path to the .spk. Optional - defaults to the newest *.spk under
# ./, ./dist, or ./clients/synology/dist (relative to the working directory).
# CATALOG_SPK=clients/synology/dist/luma-0.1.4-x86_64.spk

# Output directory for catalog + icon + index.html. Optional (default dist/repo).
# CATALOG_OUT_DIR=dist/repo

# Catalog filename. Optional (default catalog.json). Use nightly.json for a beta channel.
# CATALOG_NAME=catalog.json

# Mark packages as beta (nightly channel; needs Package Center "beta" toggle). Optional.
# CATALOG_BETA=false

# Store-card metadata. Optional.
# CATALOG_MAINTAINER=Maxime Scharwath
# CATALOG_MAINTAINER_URL=https://github.com/maxscharwath/luma
# CATALOG_DISTRIBUTOR=LUMA
# CATALOG_DISTRIBUTOR_URL=https://github.com/maxscharwath/luma
# CATALOG_CHANGELOG_URL=https://github.com/maxscharwath/luma/releases

# Path to a store icon PNG override. Optional - by default the icon is read
# straight out of the .spk (PACKAGE_ICON_256.PNG).
# CATALOG_ICON=clients/synology/spk/PACKAGE_ICON_256.PNG
