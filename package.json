{
  "name": "kroma",
  "version": "0.1.3",
  "private": true,
  "description": "KROMA self-hosted, multi-platform video streaming (Rust server + web / Tizen / webOS clients). Direct-play HEVC everywhere.",
  "workspaces": [
    "packages/*",
    "clients/*",
    "server/modules/*/ui"
  ],
  "scripts": {
    "modules:gen": "bun scripts/gen-modules.ts",
    "modules:new": "bun scripts/new-module.ts",
    "modules:validate": "bun scripts/validate-modules.ts",
    "modules:pack": "bun scripts/pack-module.ts",
    "modules:check": "bun run modules:validate && bun run modules:gen && git diff --exit-code -- server/modules server/crates/kroma-modules-generated packages/modules-generated",
    "start": "bun run tizen:prepare && bun run dev",
    "dev": "concurrently -k -n server,web,tv -c yellow,cyan,magenta \"bun run server:watch\" \"bun run dev:web\" \"VITE_KROMA_SERVER=http://localhost:4040 bun run dev:tizen\"",
    "dev:webonly": "concurrently -k -n server,web -c yellow,cyan \"bun run server:watch\" \"bun run dev:web\"",
    "dev:web": "bun run --filter '@kroma/web' dev",
    "dev:tizen": "bun run --filter '@kroma/tizen' dev",
    "dev:tizen:device": "bash clients/tizen/scripts/dev-device.sh",
    "dev:webos": "bun run --filter '@kroma/webos' dev",
    "dev:androidtv": "bun run --filter '@kroma/androidtv' dev",
    "dev:desktop": "bun run --filter '@kroma/desktop' dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --filter '@kroma/web' build",
    "build:tizen": "bun run --filter '@kroma/tizen' build",
    "build:webos": "bun run --filter '@kroma/webos' build",
    "build:androidtv": "bun run --filter '@kroma/androidtv' build",
    "build:tv": "bun run --filter '@kroma/tizen' --filter '@kroma/webos' --filter '@kroma/androidtv' build",
    "build:desktop": "bun run --filter '@kroma/desktop' build",
    "deploy:tizen": "bun run --filter '@kroma/tizen' deploy",
    "tizen:prepare": "bun run build:tizen && echo \"✓ Tizen app ready → clients/tizen/dist  (package: cd clients/tizen && tizen build-web && tizen package -t wgt -s <cert-profile> -- dist)\"",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "server": "cd server && cargo run --features semantic-embeddings,whisper-metal",
    "server:watch": "cd server && cargo watch -x 'run --features semantic-embeddings,whisper-metal'",
    "server:watch:cpu": "cd server && cargo watch -x 'run --features semantic-embeddings,whisper-local'",
    "server:watch:lexical": "cd server && cargo watch -x run",
    "server:build": "cd server && cargo build --release"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@csstools/postcss-cascade-layers": "^6.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "abortcontroller-polyfill": "^1.7.8",
    "concurrently": "^10.0.3",
    "core-js": "^3.49.0",
    "intersection-observer": "^0.12.2",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
