{
  "name": "luma",
  "version": "0.1.3",
  "private": true,
  "description": "LUMA self-hosted, multi-platform video streaming (Rust server + web / Tizen / webOS clients). Direct-play HEVC everywhere.",
  "workspaces": [
    "packages/*",
    "clients/*",
    "server/modules/*/ui"
  ],
  "scripts": {
    "modules:gen": "bun scripts/gen-modules.ts",
    "modules:new": "bun scripts/new-module.ts",
    "modules:validate": "bun scripts/validate-modules.ts",
    "modules:pack": "bun scripts/pack-module.ts",
    "modules:check": "bun run modules:validate && bun run modules:gen && git diff --exit-code -- server/modules server/crates/luma-modules-generated packages/modules-generated",
    "start": "bun run tizen:prepare && bun run dev",
    "dev": "concurrently -k -n server,web,tv -c yellow,cyan,magenta \"bun run server:watch\" \"bun run dev:web\" \"VITE_LUMA_SERVER=http://localhost:4040 bun run dev:tizen\"",
    "dev:webonly": "concurrently -k -n server,web -c yellow,cyan \"bun run server:watch\" \"bun run dev:web\"",
    "dev:web": "bun run --filter '@luma/web' dev",
    "dev:tizen": "bun run --filter '@luma/tizen' dev",
    "dev:tizen:device": "bash clients/tizen/scripts/dev-device.sh",
    "dev:webos": "bun run --filter '@luma/webos' dev",
    "dev:androidtv": "bun run --filter '@luma/androidtv' dev",
    "dev:desktop": "bun run --filter '@luma/desktop' dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --filter '@luma/web' build",
    "build:tizen": "bun run --filter '@luma/tizen' build",
    "build:webos": "bun run --filter '@luma/webos' build",
    "build:androidtv": "bun run --filter '@luma/androidtv' build",
    "build:tv": "bun run --filter '@luma/tizen' --filter '@luma/webos' --filter '@luma/androidtv' build",
    "build:desktop": "bun run --filter '@luma/desktop' build",
    "deploy:tizen": "bun run --filter '@luma/tizen' deploy",
    "tizen:prepare": "bun run build:tizen && echo \"✓ Tizen app ready → clients/tizen/dist  (package: cd clients/tizen && tizen build-web && tizen package -t wgt -s <cert-profile> -- dist)\"",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "vitest run",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "server": "cd server && cargo run --features semantic-embeddings,whisper-metal",
    "server:watch": "cd server && cargo watch -x 'run --features semantic-embeddings,whisper-metal'",
    "server:watch:cpu": "cd server && cargo watch -x 'run --features semantic-embeddings,whisper-local'",
    "server:watch:lexical": "cd server && cargo watch -x run",
    "server:build": "cd server && cargo build --release"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@csstools/postcss-cascade-layers": "^5.0.1",
    "@tailwindcss/vite": "^4",
    "@typescript/native-preview": "^7.0.0-dev.20260628.1",
    "@vitejs/plugin-react": "^4.3.4",
    "abortcontroller-polyfill": "^1.7.5",
    "concurrently": "^9.1.2",
    "core-js": "^3.40.0",
    "intersection-observer": "^0.12.2",
    "lightningcss": "^1.27.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
