# Dependencies
node_modules/
.pnpm-store/

# Bun
bun.lockb

# Builds
dist/
build/
*.tsbuildinfo
.tanstack/
# On-device TV live-dev staging (clients/tizen/.dev-shell)
.dev-shell/

# Rust
server/target/
# Standalone wasm-module crates build into their own target/ (they are their own
# cargo workspaces), which the root server/target/ rule does not cover. Plus the
# built frontend remote (fe/dist), the staging dir, and assembled bundles.
wasm-modules/*/server/target/
wasm-modules/*/ui/dist/
wasm-modules/*/.bundle/
server/data/
# ts-rs generated TypeScript bindings (regenerated from #[derive(TS)], not committed)
server/bindings/

# Desktop: downloaded kroma-mpv sidecar (clients/desktop/scripts/fetch-mpv.sh)
clients/desktop/src-tauri/bin/

# TV packaging artifacts
clients/tizen/*.wgt
clients/tizen/dist/*.wgt
clients/tizen/.buildResult/
clients/tizen/.tizen.env
clients/webos/*.ipk

# Env / local
.env
.env.local
*.local

# Local NAS serve helper kept on disk, never tracked
scripts/serve-nas.sh

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Logs
*.log

# Local runtime data dir (single-port dev: DB, WAL/SHM, logs, image cache)
/data/
